// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: admins
// Document ID: {adminId} (Firebase Auth UID)
// Fields:
//   - email: string (required) - Admin email
//   - role: string (required, enum: ['admin']) - User role
//
// Collection: students
// Document ID: {studentId} (Custom ID or Auto-ID)
// Fields:
//   - id: string (required) - Student ID/Roll number
//   - name: string (required) - Full name
//   - grade: string (optional) - Grade level
//   - dob: string (required) - Date of birth (YYYY-MM-DD)
//   - gender: string (required, enum: ['male', 'female', 'other']) - Gender
//   - createdAt: timestamp (required) - Creation time
//
// Collection: students/{studentId}/records
// Document ID: {recordId} (Auto-ID)
// Fields:
//   - studentId: string (required) - Reference to student
//   - height: number (required) - Height in cm
//   - weight: number (required) - Weight in kg
//   - bmi: number (required) - Calculated BMI
//   - timestamp: timestamp (required) - Measurement time
//   - recordedBy: string (required) - Admin UID
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "newroskoto@gmail.com" ||
         request.auth.token.email == "admin@gmail.com");
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'name', 'dob', 'gender']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.dob is string && data.dob.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.gender in ['male', 'female', 'other'] &&
             (!('grade' in data) || (data.grade is string && data.grade.size() < 20)) &&
             (!('allergies' in data) || (data.allergies is list && data.allergies.size() <= 20)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() < 1000));
    }

    function isValidBMIRecord(data) {
      return data.keys().hasAll(['studentId', 'height', 'weight', 'bmi', 'timestamp', 'recordedBy']) &&
             data.studentId is string &&
             data.height is number && data.height > 0 && data.height < 300 &&
             data.weight is number && data.weight > 0 && data.weight < 500 &&
             data.bmi is number && data.bmi > 0 && data.bmi < 100 &&
             data.recordedBy == request.auth.uid &&
             (!('healthIssues' in data) || (data.healthIssues is list && data.healthIssues.size() <= 20));
    }

    function isValidDeviceStatus(data) {
      return (!('requestBMI' in data) || data.requestBMI is bool) &&
             (!('height' in data) || data.height is number) &&
             (!('weight' in data) || data.weight is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Device communication
    match /devices/{deviceId} {
      allow read, write: if isAdmin();
      // Allow ESP32 to update if we had a way to identify it, 
      // but for now we'll assume it uses an admin-like service account or we just allow it.
      // In a real app, you'd have a specific device token.
    }

    // Admin profiles
    match /admins/{adminId} {
      // CRITICAL: Allow users to read their own admin document without calling isAdmin()
      // This prevents infinite recursion in the rules.
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      
      // Other admins can read/write admin profiles
      allow read, write: if isAdmin();
    }

    // BMI Records (Collection Group)
    match /{path=**}/records/{recordId} {
      allow read: if isAdmin();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidStudent(request.resource.data);
      allow delete: if isAdmin();

      // BMI Records sub-collection
      match /records/{recordId} {
        allow create: if isAdmin() && isValidBMIRecord(request.resource.data);
        allow update: if isAdmin() && isValidBMIRecord(request.resource.data) && 
                      request.resource.data.timestamp == resource.data.timestamp;
        allow delete: if isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
